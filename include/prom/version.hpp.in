#pragma once

/// @file
/// @brief prom version macros and `prom::version*` constants.
///
/// Generated by the build system from `version.hpp.in`; values come from
/// the CMake `project(... VERSION ...)` declaration, which is the single
/// source of truth. From C++ prefer the `prom::version*` constants below;
/// the macros are there for preprocessor-time checks.

#include <string_view>

// NOLINTBEGIN(cppcoreguidelines-macro-to-enum,modernize-macro-to-enum)
#define PROM_VERSION_MAJOR @PROJECT_VERSION_MAJOR@
#define PROM_VERSION_MINOR @PROJECT_VERSION_MINOR@
#define PROM_VERSION_PATCH @PROJECT_VERSION_PATCH@
#define PROM_VERSION_STRING "@PROJECT_VERSION@"
// NOLINTEND(cppcoreguidelines-macro-to-enum,modernize-macro-to-enum)

namespace prom {

/// Library version as a dotted string (e.g. `"0.1.0"`).
inline constexpr std::string_view version = PROM_VERSION_STRING;

/// Major version component (the `X` in `X.Y.Z`).
inline constexpr int version_major = PROM_VERSION_MAJOR;
/// Minor version component (the `Y` in `X.Y.Z`).
inline constexpr int version_minor = PROM_VERSION_MINOR;
/// Patch version component (the `Z` in `X.Y.Z`).
inline constexpr int version_patch = PROM_VERSION_PATCH;

}  // namespace prom
